# ──────────────────────────────────────────────
# Helena CRM Automação — Variáveis de Ambiente
# ──────────────────────────────────────────────

# ── Aplicação ────────────────────────────────
APP_PORT=3000
API_BASE_URL=http://localhost:3000
# OBRIGATÓRIO — gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here
# Origens permitidas pelo CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql://velox:${POSTGRES_PASSWORD}@postgres:5432/velox
POSTGRES_PASSWORD=troque_por_senha_segura
REDIS_URL=redis://redis:6379/0

# ── Helena CRM ───────────────────────────────
HELENA_API_URL=https://api.helena.run/chat/v1/message
HELENA_API_KEY=your_helena_api_key_here

# ── Center API ───────────────────────────────
CENTER_API_URL=https://api.center.example/v1
CENTER_API_KEY=your_center_api_key_here
# API de consulta de fichas (relatório detalhado)
CENTER_CONSULTA_URL=https://gbr.center.emartim.com/Publico/Consulta
CENTER_IDENTIFICADOR=your_center_identificador_here

# ── Google Drive ─────────────────────────────
# Opção 1 (recomendada): OAuth user — funciona em conta pessoal.
# Gere o refresh_token rodando: docker compose exec backend python -m app.scripts.oauth_setup
GOOGLE_DRIVE_CLIENT_ID=your_google_drive_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_google_drive_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=your_google_drive_refresh_token

# Opção 2 (legado): Service Account — só com Workspace + Shared Drive.
# Em conta pessoal, upload falha com storageQuotaExceeded.
# GOOGLE_SERVICE_ACCOUNT_FILE=/app/app/service-account.json

GOOGLE_DRIVE_ROOT_FOLDER_ID=root

# ── Inteligência Artificial (Agno + LangChain)
# Provider: "openai", "google" ou "anthropic"
AI_PROVIDER=openai
AI_CHAT_MODEL=gpt-4o
AI_TRANSCRIPTION_MODEL=whisper-1

# Chaves por provider (preencha apenas a do provider escolhido)
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
